newmem:
cmp dword ptr [pUnitMagnetData],0
je code
push rax
push rbx
push rbp
mov rbp,rsp
and spl,F0
sub rsp,50
movups [rsp+20],xmm0
movups [rsp+30],xmm1
movups [rsp+40],xmm2
// Get Player Coords
call get_Character
test rax,rax
jz end
mov rbx,rax // Player Character
// Calculate Distance from Player to Unit
db 66 0f 2a 43 50 // cvtpi2pd xmm0,qword ptr [rbx+50]
db 66 0f 2a 4f 50 // cvtpi2pd xmm1,qword ptr [rdi+50]
subpd xmm1,xmm0 // xmm1: dx,dy
movupd xmm0,xmm1
mulpd xmm0,xmm0
movhlps xmm2,xmm0
addsd xmm0,xmm2
sqrtsd xmm0,xmm0 // distance between player and unit
ucomisd xmm0,[pUnitMagnetData+8]
jp end
jae end
movlhps xmm0,xmm0
divpd xmm1,xmm0 // Normalized Direction Vector
movsd xmm2,[pUnitMagnetData+10]
movlhps xmm2,xmm2
mulpd xmm1,xmm2
db 66 0f 2a 47 50 // cvtpi2pd xmm0,qword ptr [rdi+50]
addpd xmm0,xmm1
db 66 0f 2d c0 // cvtpd2pi mm0,xmm0
db 0f 7f 47 50 // movq qword ptr [rdi+50],mm0
end:
movups xmm2,[rsp+40]
movups xmm1,[rsp+30]
movups xmm0,[rsp+20]
mov rsp,rbp
pop rbp
pop rbx
pop rax

code:
  shr rbp,20
  cmp ebx,[rdi+50]
  jmp return

align 4 CC

get_Character:
mov rax,[Factorio.Global]
test rax,rax
jz @f
  mov rax,[rax+78] // Factorio.Game
  test rax,rax
  jz @f
    mov rax,[rax+B0] // Factorio.Player
    test rax,rax
    jz @f
      mov rax,[rax+60] // Factorio.CharacterController
      test rax,rax
      jz @f
        mov rax,[rax+198] // Factorio.Character
@@:
ret

align 4 CC

pUnitMagnetData:
dd 0 // Magnet Active +0
dd 0 // Reserved +4
dq (double)3000 // Magnet Radius +8
dq (double)100 // Magnet Strength +10

unit_pos_aob:
  jmp newmem
  nop 2
return:
registersymbol(unit_pos_aob)

[DISABLE]

