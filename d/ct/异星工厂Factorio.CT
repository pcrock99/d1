        <CheatEntry>
          <ID>297</ID>
          <Description>"Bloodybone.Main"</Description>
          <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
function bloodybone_main_getfuncfromidlua(id)
  if id == 1 then
    return getAddressSafe("executefunctionbyname")
  elseif id == 2 then
    return getAddressSafe("executefunctionbyname_async")
  elseif id == 3 then
    return getAddressSafe("itemname_id_converter")
  end
  return nil
end

{$asm}
alloc(bloodybone.main,0x1000,$process)
createthread(bloodybone.main)
label(bloodybone.main.end)
label(bloodybone.main.shouldendthread)
label(bloodybone.main.threadstate)
label(bloodybone.main.luadata)
label(bloodybone.main.data)
label(bloodybone.main.lasterror)
label(bloodybone.main.getfuncfromid)
label(bloodybone.main.getfuncfromid.lua.name)
label(bloodybone.main.getaddressfromstring.lua)
label(bloodybone.main.executefunctionbyname.param.string)
registersymbol(bloodybone.main)
registersymbol(bloodybone.main.shouldendthread)
registersymbol(bloodybone.main.threadstate)
registersymbol(bloodybone.main.data)

bloodybone.main:
cmp [bloodybone.main.data],1
jne short @f
  and [bloodybone.main.data],0
  mov ecx,1
  call long bloodybone.main.getfuncfromid
  test rax,rax
  je short @f
    push rax
    mov rcx,bloodybone.main.getaddressfromstring.lua
    mov rdx,bloodybone.main.executefunctionbyname.param.string
    sub rsp,28
    call CELUA_ExecuteFunctionAsync
    add rsp,28
    mov rbx,rax
    pop rax
    test rbx,rbx
    jz short @f
      mov rcx,[bloodybone.main.data+8]
      mov rdx,[bloodybone.main.data+10]
      mov r8,[bloodybone.main.data+18]
      mov r9,[bloodybone.main.data+20]
      push [rbx] // Amount of Times to Run
      lea rbx,[rbx+4]
      push rbx // Name
      sub rsp,20
      call rax
      add rsp,30
@@:
cmp [bloodybone.main.data],2
jne short @f
  and [bloodybone.main.data],0
  mov ecx,2
  call long bloodybone.main.getfuncfromid
  test rax,rax
  je short @f
    push rax
    mov rcx,bloodybone.main.getaddressfromstring.lua
    mov rdx,bloodybone.main.executefunctionbyname.param.string
    sub rsp,28
    call CELUA_ExecuteFunctionAsync
    add rsp,28
    mov rbx,rax
    pop rax
    test rbx,rbx
    je short @f
      mov rcx,[bloodybone.main.data+8]
      mov rdx,[bloodybone.main.data+10]
      mov r8,[bloodybone.main.data+18]
      mov r9,[bloodybone.main.data+20]
      push [rbx] // Amount of Times to Run
      lea rbx,[rbx+4]
      push rbx // Name
      sub rsp,20
      call rax
      add rsp,30
@@:
cmp [bloodybone.main.data],3
jne short @f
  and [bloodybone.main.data],0
  mov ecx,3
  call long bloodybone.main.getfuncfromid
  test rax,rax
  je short @f
    mov rcx,1 // Convert ID 2 Name
    mov rdx,[bloodybone.main.data+28] // Item ID
    call rax
@@:
cmp [bloodybone.main.data],4
jne short @f
  and [bloodybone.main.data],0
  mov ecx,3
  call long bloodybone.main.getfuncfromid
  test rax,rax
  je short @f
    mov rcx,2 // Cpnvert Name 2 ID
    mov rdx,bloodybone.main.data+2C // Name
    call rax
@@:

bloodybone.main.end:
mov ecx,#100
call Kernel32.Sleep

cmp [bloodybone.main.shouldendthread],1
jne long bloodybone.main

and [bloodybone.main.threadstate],0 // Terminating

ret

bloodybone.main.getfuncfromid:
push rbx
mov rbx,ecx
mov ecx,[bloodybone.main.luadata]
test ecx,ecx
jne short @f
  mov rcx,bloodybone.main.getfuncfromid.lua.name
  call CELUA_GetFunctionReferenceFromName
  mov [bloodybone.main.luadata],eax
  mov ecx,eax
@@:
mov edx,1
sub rsp,8
mov r8,rsp
mov [r8],rbx
xor r9,r9
or r9,1
call CELUA_ExecuteFunctionByReference
add rsp,8
pop rbx
ret

bloodybone.main.shouldendthread:
dd 0

bloodybone.main.threadstate:
dd 1

bloodybone.main.getfuncfromid.lua.name:
db 'bloodybone_main_getfuncfromidlua',0

bloodybone.main.getaddressfromstring.lua:
db 'return getAddressSafe(readString(parameter))',0

bloodybone.main.executefunctionbyname.param.string:
db 'executefunctionbyname.data',0

bloodybone.main.luadata:
dd 0

bloodybone.main.lasterror:
dq 0

align 10

bloodybone.main.data:
dd 0,0
dq 0,0,0,0
dd 0 // Item ID
db '',0 // Item Name

[DISABLE]
{$lua}
if syntaxcheck then return end
local function destroymainThread(luathread)
  while true do
    writeInteger("bloodybone.main.shouldendthread",1)
    if not getAddressSafe("bloodybone.main") then
      print("Failure")
      break
    end
    if readInteger(getAddressSafe("bloodybone.main.threadstate")) == 0 then
      sleep(100)
      if deAlloc(getAddressSafe("bloodybone.main")) then
        unregisterSymbol("bloodybone.main")
        unregisterSymbol("bloodybone.main.shouldendthread")
        unregisterSymbol("bloodybone.main.threadstate")
        unregisterSymbol("bloodybone.main.data")
      else
        print("Freeing Memory Failed!")
      end
      break
    end
    sleep(0)
  end
  print("Destroying Thread Done")
  luathread.terminate()
end
createThread(destroymainThread)
</AssemblerScript>
