assert(address,bytes)
assert(address2,bytes2)

alloc(newmem,$1000,Factorio.exe)

label(return)
label(return2)
label(fromLocal)
label(fromGlobal)
label(start)
label(unlockachievement_hook.end)
label(unlockachievement_hook.data)
label(unlockachievement_hook.gotname)

newmem:
fromLocal:
mov [rsp+10],0
jmp short start

fromGlobal:
mov [rsp+10],1

start:
// Save Registers
push rcx
push rdx
push r8
push r9
push r10
push r11
push rbx
mov rbx,rcx // Factorio.Achievement
sub rsp,20
cmp [unlockachievement_hook.data],0
jne short @f
// Get SteamUserStats Interface
call steam_api64.SteamClient
test rax,rax
je short unlockachievement_hook.end
mov rcx,rax // SteamClient
mov rax,[rcx] // VTable
mov edx,1 // hSteamUser
mov r8d,1 // hSteamPipe
mov r9,unlockachievement_hook.data+8 // Interface Version
call [rax+68] // GetISteamUserStats
mov [unlockachievement_hook.data],rax
test rax,rax
je short unlockachievement_hook.end
mov rcx,rax
mov rax,[rcx] // VTable
call [rax] // RequestCurrentStats
@@:
// Get Achievement Name
mov rbx,[rbx+8] // Factorio.AchievementPrototype
lea rcx,[rbx+8] // Achievement Name
call Factorio.String.GetString
mov rdx,rax
unlockachievement_hook.gotname:
mov rcx,[unlockachievement_hook.data] // ISteamUserStats
mov rax,[rcx] // VTable
call [rax+38] // SetAchievement
mov rcx,[unlockachievement_hook.data] // ISteamUserStats
mov rax,[rcx] // VTable
call [rax+50] // StoreStats

unlockachievement_hook.end:
add rsp,20
pop rbx
pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
cmp [rsp+10],0
jne short @f
// Local OG Code
mov [rsp+08],rbx
jmp return
@@:
// Global OG Code
mov [rsp+10],rbx
jmp return2

align 10 CC

unlockachievement_hook.data:
dq 0 // SteamUserStats Interface
db 'STEAMUSERSTATS_INTERFACE_VERSION011',0 // Interface Version

address:
  jmp fromLocal
return:

address2:
  jmp fromGlobal
return2:

[DISABLE]

address:
  db bytes

address2:
  db bytes2

dealloc(newmem)

