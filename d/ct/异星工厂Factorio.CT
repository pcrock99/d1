{$asm}
alloc(executefunctionbyname,0x2000,$process)
registersymbol(executefunctionbyname_async)
registersymbol(executefunctionbyname)
label(executefunctionbyname_async)
label(executefunctionbyname_async.wrapper)
label(executefunctionbyname_async.data)
label(executefunctionbyname.data)
