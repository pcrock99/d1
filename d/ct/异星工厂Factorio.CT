          <AssemblerScript>define(address,Factorio.MainLoop::mainLoopStep+13)
define(bytes,48 81 EC C0 00 00 00)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,Factorio.MainLoop::mainLoopStep)

label(code)
label(return)
label(technology_getall)
label(technology_data)
label(technology_end)
registersymbol(technology_data)

newmem:
cmp [technology_data],1
jne short @f

  and [technology_data],0

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11

  call long technology_getall
  test rax,rax
  je long technology_end
    mov rcx,rax
    mov edx,1
    sub rsp,28
    call Factorio.ForceData::researchAllTechnologies
    add rsp,28
    jmp long technology_end
@@:
cmp [technology_data+4],1
jne long code

  and [technology_data+4],0
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11

  call long technology_getall
  test rax,rax
  je long technology_end
    mov rcx,rax
    sub rsp,28
    call Factorio.ForceData::resetResearchAndEffects
    add rsp,28

  technology_end:
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax

code:
