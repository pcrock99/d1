          <AssemblerScript>define(address,Factorio.Surface::update)
define(bytes,48 89 5C 24 18)

[ENABLE]
{$lua}
if syntaxcheck then return end
EnemySpawnerVFTable = getAddressSafe("Factorio.EnemySpawner::`vftable'") or 0
UnitVFTable = getAddressSafe("Factorio.Unit::`vftable'") or 0
{$asm}

assert(address,bytes)
alloc(newmem,$1000,Factorio.Surface::update)

label(code)
label(return)
label(pSurfaceData)
registersymbol(pSurfaceData)

label(DestroyEnemiesHandler)
label(DestroyEnemiesHandler.loop)
label(DestroyEnemiesHandler.l1)
label(DestroyEnemiesHandler.l2)
label(DestroyEnemiesHandler.l3)
label(DestroyEnemiesHandler.end)

newmem:
push rbx
sub rsp,20
mov rbx,rcx
call DestroyEnemiesHandler
mov rcx,rbx
add rsp,20
pop rbx

code:
  mov [rsp+18],rbx
  jmp return

align 4 CC

DestroyEnemiesHandler:
push rbx
push rsi
push rdi
sub rsp,40
cmp dword ptr [pSurfaceData],0
je DestroyEnemiesHandler.end
mov rbx,rcx
// Get Current Surface
call Factorio.Global.GetCurrentSurface
test rax,rax
jz DestroyEnemiesHandler.end
cmp rax,rbx
jne DestroyEnemiesHandler.end
mov [pSurfaceData],0
// Current Surface
mov rcx,rbx
lea rdx,[rsp+20]
call Factorio.Surface::findAllEntities
mov rsi,[rsp+20] // Array&lt;Entity&gt;
mov rdi,[rsp+28] // End of Array
test rsi,rsi
jz DestroyEnemiesHandler.end
test rdi,rdi
jz DestroyEnemiesHandler.end
DestroyEnemiesHandler.loop:
cmp rsi,rdi
je DestroyEnemiesHandler.l1
  mov rcx,[rsi] // Entity
  test rcx,rcx
  jz DestroyEnemiesHandler.l3
  cmp dword ptr [pSurfaceData+4],0
  jne DestroyEnemiesHandler.l2
    cmp dword ptr [pSurfaceData+8],0
    je short @f
      // Destroy Spawner types
      mov rdx,$EnemySpawnerVFTable
      test rdx,rdx
      jz short @f
      cmp [rcx],rdx
      jne short @f
      call Factorio.Entity::forceDestroy
    @@:
    cmp dword ptr [pSurfaceData+C],0
    je short @f
      // Destroy Unit Types
      mov rdx,$UnitVFTable
      test rdx,rdx
      jz short @f
      cmp [rcx],rdx
      jne short @f
      call Factorio.Entity::forceDestroy
    @@:
    jmp DestroyEnemiesHandler.l3
  DestroyEnemiesHandler.l2:
  // Destroy all Enemies // Check for ForceData!
  call Entity::getForceData
  test rax,rax
  jz DestroyEnemiesHandler.l3
  mov rcx,rax
  mov edx,1
  call Factorio.ForceData::isEnemy
  test al,al
  jz DestroyEnemiesHandler.l3
    mov rcx,[rsi]
    call Factorio.Entity::forceDestroy
  DestroyEnemiesHandler.l3:
  add rsi,8
  jmp DestroyEnemiesHandler.loop
DestroyEnemiesHandler.l1:
mov rcx,[rsp+20] // Array&lt;Entity&gt;
test rcx,rcx
jz DestroyEnemiesHandler.end
mov rax,[rsp+30]
sub rax,rcx
sar rax,3
lea rdx,[rax*8]
mov rax,rcx
cmp rdx,1000
jb short @f
  add rdx,27
  mov rcx,[rcx-8]
  sub rax,rcx
  sub rax,8
  cmp rax,1F
  ja DestroyEnemiesHandler.end
@@:
call Factorio.free

DestroyEnemiesHandler.end:
add rsp,40
pop rdi
pop rsi
pop rbx
ret

align 4 CC

pSurfaceData:
// Destroy Enemies on Surface Handler
dd 0 // Destroy Enemies +0x0
dd 1 // Destroy all Enemy types +0x4
dd 0 // Destroy Spawner Enemy types +0x8
dd 0 // Destroy Unit Enemy types +0xC

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes
  // mov [rsp+18],rbx

dealloc(newmem)
unregistersymbol(pSurfaceData)

{
// ORIGINAL CODE - INJECTION POINT: Factorio.Surface::update

Factorio.exe+EB0FC6: CC              - int 3 
