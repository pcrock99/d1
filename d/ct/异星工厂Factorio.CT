        <CheatEntry>
          <ID>474</ID>
          <Description>"ElectricNetworkManager List Networks"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
local electricNetworkManager = 0x233DB1B43E0

local lastNetwork = readPointer(electricNetworkManager+0x10)

printf("Last/First ElectricNetwork: %X",lastNetwork)

assert(lastNetwork ~= nil and lastNetwork ~= 0)

local networkCount = 1
local nextNetwork = 0

while(lastNetwork ~= nextNetwork ) do
  if (nextNetwork == 0) then nextNetwork = lastNetwork end
  networkCount = networkCount + 1
  printf("Current Network Address: %X",nextNetwork)
  printf("Next Network Address: %X",readPointer(nextNetwork) or 0)
  local flag = readBytes(nextNetwork+0x20,1,false)
  local flagString = 'N/A'
  if (flag == 0) then
    flagString = 'Should have Statistics'
  elseif (flag == 1) then
    flagString = "Shouldn't have Statistics"
  elseif (flag == 2) then
    flagString = "Not part of GameState"
  end
  print("Network state: "..flagString)
  printf("Network Statistics Address: %X",readPointer(nextNetwork+0x70) or 0)
  print("")
  nextNetwork = readPointer(nextNetwork) or 0
  if (nextNetwork == 0) then error("nextNetwork is 0") end
end

print("Network Count: "..networkCount)
[DISABLE]
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>475</ID>
          <Description>"Fix Electric Network"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.ElectricNetworkManager::update)
define(bytes,48 89 5C 24 08)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Factorio.ElectricNetworkManager::update)

label(code)
label(return)
label(data)
label(l1)
label(l2)
label(l3)

newmem:
cmp dword ptr [data],0
jne code
mov dword ptr [data],1
push rbx
push rsi
sub rsp,48
mov [rsp+20],rcx
mov [rsp+28],rdx
mov [rsp+30],r8
mov [rsp+38],r9
mov rbx,[rcx+10] // First/Last ElectricNetwork
xor rsi,rsi
l1:
cmp rbx,rsi
je l2
  test rsi,rsi
  cmovz rsi,rbx // nextNetwork
  cmp byte ptr [rsi+20],0
  jg l3
    // Should have Statistics
    cmp qword ptr [rsi+70],0 // Statistics
    je short @f
      // Check for Valid Address
      mov rcx,[rsi+70]
      mov edx,8
      call Kernel32.IsBadReadPtr
      test al,al
      jz l3 // Valid Address
    @@:
    // Invalid Address
    // Create New
    mov ecx,[data+4] // Alloc Size
    call [data+8] // Allocator
    mov rcx,rax
    //mov [rsp+40],rax
    test rax,rax
    jnz short @f
      int 3
    @@:
    call "Factorio.FlowStatistics&lt;IDWithQuality&lt;ID&lt;EntityPrototype,unsigned short&gt; &gt;,double,ElectricityTag&gt;::FlowStatistics&lt;IDWithQuality&lt;ID&lt;EntityPrototype,unsigned short&gt; &gt;,double,ElectricityTag&gt;"
    mov [rsi+70],rax
    test rax,rax
    jnz l3
    int 3
  l3:
  mov rsi,[rsi] // nextNetwork.nextNetwork
  test rsi,rsi
  jnz l1
l2:
mov r9,[rsp+38]
mov r8,[rsp+30]
mov rdx,[rsp+28]
mov rcx,[rsp+20]
add rsp,48
pop rsi
pop rbx

code:
  mov [rsp+08],rbx
  jmp return

align 10 CC

data:
dd 0 // Was run +0
dd 4C8 // Alloc Size +4
dq Factorio.exe+19ACA00 // Allocator +8

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes

dealloc(newmem)

{
// ORIGINAL CODE - INJECTION POINT: Factorio.ElectricNetworkManager::update

