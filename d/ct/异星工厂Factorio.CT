          <AssemblerScript>define(address,Factorio.ItemStack::swapWith)
define(bytes,40 55 41 54 41 57)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Factorio.ItemStack::swapWith)

label(code)
label(return)
label(getcursor)
label(getcharacter)
label(placeholder)
label(clonetoplaceholder)

newmem:
sub rsp,8
call long getcursor
cmp rcx,rax
je @f
cmp rdx,rax
jne code
cmp word ptr [rcx+4],0
jne code
mov [rsp],rcx
mov rcx,rdx
call clonetoplaceholder
mov rcx,[rsp]
mov rdx,rax
jmp code
@@:
cmp word ptr [rcx+4],0
jne code
call clonetoplaceholder
mov rcx,rax

code:
  add rsp,8
  push rbp
  push r12
  push r15
  jmp return

getcursor:
call Factorio.Global.GetCursor
ret

getcharacter:
call Factorio.Global.GetCharacter
ret

clonetoplaceholder:
push rbx
push r12
mov r12,6
lea rbx,[placeholder]
@@:
dec r12
js short @f
mov rax,[rcx+r12*8]
mov [rbx+r12*8],rax
jmp short @b
@@:
mov rax,rbx
pop r12
pop rbx
ret

align 4 CC

placeholder:

address:
  jmp newmem
  nop
return:

[DISABLE]

address:
  db bytes

dealloc(newmem)

{
