          <AssemblerScript>define(address,Factorio.Unit::update)
define(bytes,40 53 55 56 57)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,Factorio.Unit::update)

label(return)
label(pUnitMagnetData)
registersymbol(pUnitMagnetData)

label(get_Character)

label(end)

newmem:
push rbx
push rbp
push rsi
push rdi
cmp dword ptr [pUnitMagnetData],0
je return
push rcx
push rdx
sub rsp,48
call Factorio.Unit::asEntity
mov rdi,rax
// Get Player Coords
call get_Character
test rax,rax
jz end
mov rbx,rax // Player Character
// Calculate Distance from Player to Unit
db 66 0f 2a 40 50 // cvtpi2pd xmm0,QWORD PTR [rax+0x50]
db 66 0f 2a 4f 50 // cvtpi2pd xmm1,QWORD PTR [rdi+0x50]
subpd xmm1,xmm0 // xmm1: dx,dy
movupd xmm0,xmm1
mulpd xmm0,xmm0
movhlps xmm2,xmm0
addsd xmm0,xmm2
sqrtsd xmm0,xmm0 // distance between player and unit
ucomisd xmm0,[pUnitMagnetData+8]
jp end
jae end
movlhps xmm0,xmm0
divpd xmm1,xmm0 // Normalized Direction Vector
//movsd xmm2,[pUnitMagnetData+10]
//movlhps xmm2,xmm2
//mulpd xmm1,xmm2
//db 66 0f 2a 47 50 // cvtpi2pd xmm0,QWORD PTR [rdi+0x50]
//addpd xmm0,xmm1
//db 66 0f 2d c0 // cvtpd2pi mm0,xmm0
//db 41 0f 7f 46 50 // movq qword ptr [r14+50],mm0
movupd [rsp+20],xmm1
lea rdx,[rsp+20]
mov rcx,rdi
call Factorio.Entity::changePosition
end:
add rsp,48
pop rdx
pop rcx
jmp return

align 4 CC

get_Character:
call Factorio.Global.GetCharacter
ret

align 4 CC

pUnitMagnetData:
dd 0 // Magnet Active +0
dd 0 // Reserved +4
dq (double)3000 // Magnet Radius +8
//dq (double)100 // Magnet Strength +10

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes

dealloc(newmem)

