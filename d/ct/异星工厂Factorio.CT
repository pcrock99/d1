      <CheatEntries>
        <CheatEntry>
          <ID>11</ID>
          <Description>"Inf Health/OneHitKill"</Description>
          <Options moHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.EntityWithHealth::setHealthRatio)
define(bytes,48 89 5C 24 08)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,address)

label(return)
label(end)
label(end_2)
label(player)
label(string_1)
label(string_2)
label(setHealth_data)
registersymbol(setHealth_data)

newmem:
mov [rsp+08],rbx

sub rsp,38
mov rbx,rcx
movups [rsp+20],xmm1
mov rcx,[rcx+48] // &lt;T&gt;Prototype
test rcx,rcx
jz end
lea rcx,[rcx+8]
call Factorio.String.GetString
test rax,rax
jz end
mov rcx,rax
lea rdx,[string_1]
call ntdll.strcmp
test eax,eax
jz player

mov rcx,rbx
call Factorio.Entity::getForceData
test rax,rax
jz end
lea rcx,[rax+10]
call Factorio.String.GetString
mov rcx,rax
lea rdx,[string_2]
call ntdll.strcmp
jnz end

// Enemy

cmp [setHealth_data+4],1
jne end
  xorps xmm1,xmm1
  jmp end_2

player:
  cmp [setHealth_data],1
  jne end
  mov ecx,3F800000
  movd xmm1,ecx
  jmp end_2

end:
movups xmm1,[rsp+20]
end_2:
mov rcx,rbx
add rsp,38
jmp return

align 4 CC

setHealth_data:
dd 0 // Player Godmode
dd 0 // OHK Enemies

string_1:
db 'character',0
string_2:
db 'enemy',0

address:
  jmp newmem
return:

[DISABLE]

address:
  db 48 89 5C 24 08

dealloc(newmem)
unregistersymbol(setHealth_data)

