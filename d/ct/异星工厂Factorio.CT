              <ID>350</ID>
              <Description>"Print/Convert Item IDs and Names"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
function luaprint_lua(type,param1,param2)
  if type == 1 then
    print(readString(param1,256).."\n")
    return 1
  elseif type == 2 then
    print("ItemID: "..param1)
    print("ItemName: "..readString(param2,256).."\n")
    return 1
  end
  return 0
end

{$asm}
alloc(itemname_id_converter,0x1000,$process)
registersymbol(itemname_id_converter)
label(itemname_id_converter.internaldata)
label(itemname_id_converter.error_namenotfound)
label(itemname_id_converter.strcmp)
label(convertid2name)
label(convertid2name.end)
label(convertname2id)
label(convertname2id.end)
label(luaprint)
label(luaprint.stackaligned)
label(itemname_id_converter.validateptr)

itemname_id_converter:
cmp rcx,1
jne short @f
  call long convertid2name
  ret
@@:
cmp rcx,2
jne short @f
  call long convertname2id
  ret
@@:
xor rax,rax
ret

convertid2name:
push rbx
push rdi
push rsi
mov rbx,[Factorio.PrototypeList&lt;ItemPrototype&gt;::sortedPrototypes]
mov rdi,[Factorio.PrototypeList&lt;ItemPrototype&gt;::sortedPrototypes+8]
lea rsi,[rbx+rdx*8]
cmp rsi,rdi
ja short convertid2name.end
  mov rsi,[rbx+rdx*8]
  test rsi,rsi
  je short convertid2name.end
  mov rcx,[rsi+8]
  call long itemname_id_converter.validateptr
  test al,al
  je short @f
    mov r8,[rsi+8]
    mov rcx,2
    call long luaprint
    mov rax,[rsi+8]
    jmp short convertid2name.end
  @@:
  lea r8,[rsi+8]
  mov rcx,2
  call long luaprint
  lea rax,[rsi+8]
convertid2name.end:
pop rsi
pop rdi
pop rbx
ret

convertname2id:
push rbx
push rsi
push r12
push r13
push r14
mov rsi,rdx
xor r13,r13
mov rbx,[Factorio.PrototypeList&lt;ItemPrototype&gt;::sortedPrototypes]
mov r14,[Factorio.PrototypeList&lt;ItemPrototype&gt;::sortedPrototypes+8]
@@:
inc r13
cmp rbx,r14
ja long convertname2id.end
  mov r12,[rbx]
  add rbx,8
  mov rcx,r12
  call long itemname_id_converter.validateptr
  test rax,rax
  je short @b
    mov rcx,rsi
    lea rdx,[r12+8] // Name / *Name
    call long itemname_id_converter.strcmp
    test al,al
    jne short @f
      mov rcx,[r12+8]
      call long itemname_id_converter.validateptr
      test al,al
      je short @b
        mov rdx,rsi
        call long itemname_id_converter.strcmp
        test al,al
        je short @b
    @@:
    mov rcx,[r12+8]
    call long itemname_id_converter.validateptr
    test al,al
    je short @f
      mov rcx,2
      mov rdx,r13
      mov r8,[r12+8]
      call long luaprint
      mov rax,r13
      pop r14
      pop r13
      pop r12
      pop rsi
      pop rbx
      ret
    @@:
    mov rcx,2
    mov rdx,r13
    lea r8,[r12+8]
    call long luaprint
    mov rax,r13
    pop r14
    pop r13
    pop r12
    pop rsi
    pop rbx
    ret

convertname2id.end:
mov rcx,1
mov rdx,itemname_id_converter.error_namenotfound
call long luaprint
pop r14
pop r13
pop r12
pop rsi
pop rbx
ret

luaprint:
push rbx
push rdi
push rsi
test spl,8
je short @f
  sub rsp,8
  and [luaprint.stackaligned],0
@@:
mov rbx,rcx
mov rdi,rdx
mov rsi,r8
mov ecx,[itemname_id_converter.internaldata]
test ecx,ecx
jne short @f
  mov rcx,itemname_id_converter.internaldata+4
  call CELUA_GetFunctionReferenceFromName
  mov ecx,eax
@@:
mov edx,3
sub rsp,20
mov r8,rsp
mov [r8],rbx
mov [r8+8],rdi
mov [r8+10],rsi
xor r9,r9
call CELUA_ExecuteFunctionByReference
add rsp,20
cmp [luaprint.stackaligned],1
je short @f
   add rsp,8
@@:
or [luaprint.stackaligned],1
pop rsi
pop rdi
pop rbx
ret

itemname_id_converter.strcmp:
push rsi
push rdi
mov rsi,rcx
mov rdi,rdx
xor rax,rax
dec rdi
@@:
lodsb
test al,al
je short @f
inc rdi
cmp [rdi],al
je short @b
  xor al,al
  pop rdi
  pop rsi
  ret
@@:
inc rdi
cmp [rdi],al
je short @f
  pop rdi
  pop rsi
  xor al,al
  ret
@@:
pop rdi
pop rsi
mov al,1
ret

itemname_id_converter.validateptr:
test rcx,rcx
je short @f
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  mov rdx,8
  sub rsp,20
  call Kernel32.IsBadReadPtr
  add rsp,20
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  test rax,rax
  jne short @f
    mov al,1
    ret
@@:
xor rax,rax
ret

luaprint.stackaligned:
dd 1

itemname_id_converter.internaldata:
dd 0
db 'luaprint_lua',0
itemname_id_converter.error_namenotfound:
db 'No Item with this Name Found!',0

[DISABLE]
dealloc(itemname_id_converter)
unregistersymbol(itemname_id_converter)
