        <CheatEntry>
          <ID>441</ID>
          <Description>"Items don't spoil"</Description>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
aobscanmodule(spoilage_aob,Factorio.exe,48 8B 7C CD 00)
alloc(newmem,$1000,spoilage_aob)

label(code)
label(return)
label(spoil_end)
label(spoil_data)

newmem:

code:
  mov rdi,[rbp+rcx*8+00] // Targeter&lt;Item,3,0&gt;
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push rsi
  push rbp
  mov rbp,rsp
  and spl,F0
  sub rsp,30
  test rdi,rdi
  jz spoil_end
  mov rsi,[rdi+8] // Item
  test rsi,rsi
  jz spoil_end

  mov rcx,rsi
  movsd xmm1,[spoil_data]
  call Factorio.Item::setSpoilPercent

  spoil_end:
  mov rsp,rbp
  pop rbp
  pop rsi
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax
  jmp return

align 4 CC

spoil_data:
dq 0 // New Spoil Percent

spoilage_aob:
  jmp newmem
return:
registersymbol(spoilage_aob)

[DISABLE]

spoilage_aob:
  db 48 8B 7C CD 00

unregistersymbol(spoilage_aob)
