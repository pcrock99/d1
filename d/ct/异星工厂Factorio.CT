label(Factorio.luaprintfunc)

HelperMem:

Factorio.String.IsPointer: // bool String.IsPointer(fString str)

db 31 C0 // xor eax,eax
cmp dword ptr [rcx+18],F
seta al
ret

align 4 CC

Factorio.String.GetLength: // uint String.GetLength(fString str)
mov eax,[rcx+10]
ret

align 4 CC

Factorio.String.IsValid: // bool String.IsValid(fString str)
db 31 C0 // xor eax,eax
test rcx,rcx
jnz short @f
  ret
@@:
sub rsp,28
mov [rsp+20],rcx
call Factorio.String.GetString
mov rcx,rax
call ntdll.strlen
mov rcx,[rsp+20]
mov edx,1
xor r8d,r8d
cmp [rcx+10],eax
cmove r8d,edx
mov eax,r8d
add rsp,28
ret

align 4 CC

Factorio.String.GetString: // char* String.GetString(fString str)
cmp dword ptr [rcx+18],F
mov rax,rcx
cmova rax,[rcx]
ret

align 4 CC

Factorio.String.strcmp: // uint String.strcmp(fString str1, char* str2)
call Factorio.String.GetString
mov rcx,rax
call ntdll.strcmp
ret

Factorio.PrintToLua: // void PrintToLua(char* stringToPrint)
test rcx,rcx
jz short @f
  push rbp
  mov rbp,rsp
  sub rsp,20
  and spl,F0 // Align Stack
  mov rdx,rcx
  lea rcx,[Factorio.luaprintfunc]
  call CELUA_ExecuteFunction
  mov rsp,rbp
  pop rbp
@@:
ret

align 4 CC

Factorio.Lua.LuaPop: // void Lua.LuaPop(luaState *L, int n)
sub rsp,28
test rcx,rcx
jz short @f
  db 31 C0 // xor eax,eax
  sub eax,edx
  dec eax
  mov edx,eax
  call Factorio.lua_settop
@@:
add rsp,28
ret

align 4 CC

Factorio.Global.GetGame:
mov rax,[Factorio.Global]
test rax,rax
jz short @f
  mov rax,[rax+68] // Factorio.Game
@@:
ret

