        <CheatEntry>
          <ID>476</ID>
          <Description>"Print VFTable"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local vftable = getAddressSafe("Factorio.Entity::`vftable'")

local i = 0
while (i&lt;1000) do
  local f = readPointer(vftable+i*8)
  if (not f) or f == 0 then break end
  i = i+1
  print(getNameFromAddress(f))
end

{$asm}
[DISABLE]
