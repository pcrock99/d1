label(telecursor_end)
registersymbol(telecursor_data)

newmem:
cmp [telecursor_data],1
jne code

  and [telecursor_data],0

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push rbx
  push rbp
  mov rbp,rsp
  and spl,F0
  sub rsp,20

  test rcx,rcx
  je telecursor_end

    mov rbx,rcx // Factorio.Player

    lea rdx,[telecursor_data+4] // rdx = Container for Returned Position

    call Factorio.Player::getCursorMapPosition

    test rbx,rbx
    je telecursor_end
    mov rcx,rbx
    call Factorio.Player::getCharacter
    test rax,rax
    jz telecursor_end
    mov rcx,rax
    mov rdx,[telecursor_data+4]
    mov r8,0
    xor r9d,r9d
    call Factorio.Entity::teleport

  telecursor_end:
  mov rsp,rbp
  pop rbp
  pop rbx
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax

