    <CheatEntry>
      <ID>384</ID>
      <Description>"Lua Helper Stuff"</Description>
      <Color>C0C0C0</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
[ENABLE]
if syntaxcheck then return end
local function Factorio_String_IsPointer(factoriostring)
  if (readInteger(factoriostring+0x18) ~= 0xF) then return true end
  return false
end

local function Factorio_String_GetLength(factoriostring)
  return readInteger(factoriostring+0x10)
end

local function Factorio_String_IsValid(factoriostring)
  local v = readQword(factoriostring)
  if (v == 0 or v == nil) then return false end
  local function getStringSizeRecursive(astring)
    local cstring = astring
    local byte = 0
    repeat
      byte = readBytes(cstring,1,false)
      astring = astring+1
    until byte == 0 or byte == nil
    return astring - cstring -1
  end

  local s = factoriostring
  if Factorio_String_IsPointer(factoriostring) then
    s = readQword(s)
  end
  if (getStringSizeRecursive(s) == Factorio_String_GetLength(factoriostring)) then return true end
  return false
end

local function Factorio_GetLuaMethods_FromClass(classname) -- classname: The Class Name ex: "LuaPlayer"
  if type(classname) ~= "string" then return nil end
  local gfmfunc = getAddressSafe(string.format("Factorio.LuaBinder&lt;%s&gt;::getFunctionMap",classname))
  if gfmfunc == nil then
    print(string.format("getFunctionMap Function for Class '%s' not Found",classname))
    return nil
  end
  local fmap = executeCodeEx(1, 1000, gfmfunc)
  if fmap == 0 then
    print("Something went wrong while trying to get the Function Map")
    return nil
  end
  local functions_lua = readQword(fmap)
  if functions_lua == 0 then
    print("Error while trying to get List of Lua Functions")
    return nil
  end
  local return_functions = {}
  local i = 0

  while(readQword(functions_lua) ~= 0) do
    i=i+1
    local cfunction = {name = "", address = 0}
    if (Factorio_String_IsPointer(functions_lua)) then
      -- String Is Pointer
      cfunction ["name"] = readString(readQword(functions_lua),Factorio_String_GetLength(functions_lua)+1)
    else
      -- String Is No Pointer
      cfunction ["name"] = readString(functions_lua,Factorio_String_GetLength(functions_lua)+1)
    end
    cfunction ["address"] = readQword(functions_lua+0x20)

    return_functions[i] = cfunction

    functions_lua = functions_lua+0x38
  end

  return return_functions
end

local function Factorio_GetLuaGenericValues_FromClass(classname, protection)
  if type(classname) ~= "string" then return nil end
  if type(protection) ~= "string" then return nil end
  local gfmfunc = getAddressSafe(string.format("Factorio.LuaBinder&lt;%s&gt;::get%sIndexMap",classname,protection))
  if gfmfunc == nil then
    print(string.format("get%sIndexMap Function for Class '%s' not Found",protection,classname))
    return nil
  end
  local fmap = executeCodeEx(1, 1000, gfmfunc)
  if fmap == 0 then
    print(string.format("Something went wrong while trying to get the %sIndex Map",protection))
    return nil
  end
  local functions_lua = readQword(fmap)
  if functions_lua == 0 then
    print(string.format("Error while trying to get List of %s Values",protection))
    return nil
  end
  local return_functions = {}
  local i = 0

  while(readQword(functions_lua) ~= 0) do
    i=i+1
    if (not Factorio_String_IsValid(functions_lua)) then break end

    local cfunction = {name = "", address = 0}
    if (Factorio_String_IsPointer(functions_lua)) then
      -- String Is Pointer
      cfunction ["name"] = readString(readQword(functions_lua),Factorio_String_GetLength(functions_lua)+1)
    else
      -- String Is No Pointer
      cfunction ["name"] = readString(functions_lua,Factorio_String_GetLength(functions_lua)+1)
    end
    cfunction ["address"] = readQword(functions_lua+0x20)

    return_functions[i] = cfunction

    functions_lua = functions_lua+0x38
  end

  return return_functions
end

local function Factorio_GetLuaReadValues_FromClass(classname)
  return Factorio_GetLuaGenericValues_FromClass(classname,"Read")
end


local function Factorio_GetLuaWriteValues_FromClass(classname)
  return Factorio_GetLuaGenericValues_FromClass(classname,"Write")
end

--[[local classname = "LuaForce"

local funcs = Factorio_GetLuaMethods(classname)

local outstring = ""

print("Class Name: "..classname)

for _,v in ipairs(funcs) do
  outstring = string.format("%s\nName: %s\nAddress: %X\n",outstring,v["name"],v["address"])
end

print(outstring)]]
[DISABLE]
</AssemblerScript>
    </CheatEntry>
  </CheatEntries>
  <UserdefinedSymbols/>
  <Comments>By Bloodybone
Ignore:
