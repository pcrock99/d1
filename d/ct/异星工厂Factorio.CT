label(executefunctionbyname.strcpy)
label(executefunctionbyname.error)
label(executefunctionbyname.errorcode_nofunctionfound)
label(executefunctionbyname.errorcode_functionchanged)
label(executefunctionbyname.errorcode_functionnotexecutable)
label(executefunctionbyname.errorcode_page_readonly)
label(executefunctionbyname.errorcode_page_readwrite)
label(executefunctionbyname.errorcode_page_writecopy)
label(executefunctionbyname.errorcode_page_guard)
label(executefunctionbyname.errorcode_page_nocache)
label(executefunctionbyname.errorcode_page_writecombine)
label(executefunctionbyname.errorcode_page_unknown)
label(executefunctionbyname.luaprint)
label(executefunctionbyname.virtualbuffer)
label(executefunctionbyname.virtualprotectioncheck.startother)
registersymbol(executefunctionbyname.lasterror)
registersymbol(executefunctionbyname.data)

// function executefunctionbyname(Parameter1,Parameter2,Parameter3,Parameter4,*name,times)
executefunctionbyname:
push rbp
mov rbp,rsp
push rbx
push rcx
push rdx
push r8
push r9
push r10
push r11
push r12

mov rcx,executefunctionbyname.lua
mov rdx,[rbp+30]
sub rsp,20
call CELUA_ExecuteFunctionAsync
add rsp,20

mov rbx,rax
xor rax,rax
test rbx,rbx
jnz short @f
  mov rcx,executefunctionbyname.errorcode_nofunctionfound
  jmp long executefunctionbyname.error
@@:
mov r12d,[rbp+38]
test r12d,r12d
jg short executefunctionbyname.loop
  mov r12d,1
executefunctionbyname.loop:
test rbx,rbx
jnz short @f
  mov rcx,executefunctionbyname.errorcode_functionchanged
  jmp long executefunctionbyname.error
@@:
mov rcx,rbx
mov rdx,executefunctionbyname.virtualbuffer
mov r8,100
sub rsp,20
call Kernel32.VirtualQuery
add rsp,20
mov eax,[executefunctionbyname.virtualbuffer+24] // Page Protection
cmp eax,100
jb short executefunctionbyname.virtualprotectioncheck.startother
  cmp eax,200
  jge short @f
    mov rcx,executefunctionbyname.errorcode_page_guard
    jmp long executefunctionbyname.error
  @@:
  jne short @f
    mov rcx,executefunctionbyname.errorcode_page_nocache
    jmp long executefunctionbyname.error
  @@:
  cmp eax,400
  jne short @f
    mov rcx,executefunctionbyname.errorcode_page_writecombine
    jmp long executefunctionbyname.error
  @@:
  mov rcx,executefunctionbyname.errorcode_page_unknown
  jmp long executefunctionbyname.error
executefunctionbyname.virtualprotectioncheck.startother:
cmp al,1
jne short @f
  mov rcx,executefunctionbyname.errorcode_functionnotexecutable
  jmp long executefunctionbyname.error
@@:
cmp al,2
jne short @f
  mov rcx,executefunctionbyname.errorcode_page_readonly
  jmp long executefunctionbyname.error
@@:
cmp al,4
jne short @f
  mov rcx,executefunctionbyname.errorcode_page_readwrite
  jmp long executefunctionbyname.error
@@:
cmp al,8
jne short @f
  mov rcx,executefunctionbyname.errorcode_page_writecopy
  jmp long executefunctionbyname.error
@@:
mov rcx,[rbp-10]
mov rdx,[rbp-18]
mov r8,[rbp-20]
mov r9,[rbp-28]
sub rsp,20
call rbx
add rsp,20
dec r12d
test r12d,r12d
jnz long executefunctionbyname.loop
xor rax,rax

executefunctionbyname.end:
pop r12
pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
pop rbx
mov rsp,rbp
pop rbp
ret

executefunctionbyname.error:
push rcx
mov rcx,executefunctionbyname.luaprint
mov rdx,[rsp]
sub rsp,28
call CELUA_ExecuteFunction
add rsp,28
pop rcx
mov rdx,executefunctionbyname.lasterror
call long executefunctionbyname.strcpy
jmp long executefunctionbyname.end

executefunctionbyname.strcpy:
push rsi
push rdi
mov rsi,rcx
mov rdi,rdx
@@:
lodsb
mov [rdi],al
inc rdi
test al,al
jnz short @b
pop rdi
pop rsi
mov rax,rdx
ret

executefunctionbyname.errorcode_nofunctionfound:
db 'No Function with this Name found',0
executefunctionbyname.errorcode_functionchanged:
db 'Function is null',0
executefunctionbyname.errorcode_functionnotexecutable:
db 'Page is protected with the PAGE_NOACCESS attribute and can not be executed!',0
executefunctionbyname.errorcode_page_readonly:
db 'Page is protected with the PAGE_READONLY attribute!',0
executefunctionbyname.errorcode_page_readwrite:
db 'Page is protected with the PAGE_READWRITE attribute!',0
executefunctionbyname.errorcode_page_writecopy:
db 'Page is protected with the PAGE_WRITECOPY attribute!',0
executefunctionbyname.errorcode_page_guard:
db 'Page is protected with the PAGE_GUARD attribute!',0
executefunctionbyname.errorcode_page_nocache:
db 'Page is protected with the PAGE_NOCACHE attribute!',0
executefunctionbyname.errorcode_page_writecombine:
db 'Page is protected with the PAGE_WRITECOMBINE attribute!',0
executefunctionbyname.errorcode_page_unknown:
db 'Page is protected with an unknown attribute!',0

executefunctionbyname.lua:
db 'return getAddressSafe(readString(parameter,256))',0

executefunctionbyname.luaprint:
db 'print(readString(parameter,256))',0

executefunctionbyname.lasterror:
db ''

executefunctionbyname+700:
executefunctionbyname.virtualbuffer:

executefunctionbyname+1000:
executefunctionbyname_async:
mov [executefunctionbyname_async.data],rcx
mov [executefunctionbyname_async.data+8],rdx
mov [executefunctionbyname_async.data+10],r8
mov [executefunctionbyname_async.data+18],r9
mov rax,[rsp+28]
mov [executefunctionbyname_async.data+20],rax
mov rax,[rsp+30]
mov [executefunctionbyname_async.data+28],rax
// Setup Thread
xor rcx,rcx // lpThreadAttributes
xor rdx,rdx // dwStackSize
mov r8,executefunctionbyname_async.wrapper // lpStartAddress
mov r9,executefunctionbyname_async.data // lpParameter
xor rax,rax
push 0 // lpThreadId
push 0 // dwCreationFlags
sub rsp,20
call Kernel32.CreateThread
add rsp,30
ret

executefunctionbyname_async.wrapper:
mov rbx,rcx
mov rcx,[rbx]
mov rdx,[rbx+8]
mov r8,[rbx+10]
mov r9,[rbx+18]
push [rbx+28]
push [rbx+20]
sub rsp,20
call long executefunctionbyname
add rsp,30
ret

executefunctionbyname_async.data:
dq 0,0,0,0,0,0

executefunctionbyname.data:
dd 1
db ''

[DISABLE]
dealloc(executefunctionbyname)
unregistersymbol(executefunctionbyname)
unregistersymbol(executefunctionbyname_async)
unregistersymbol(executefunctionbyname.data)
unregistersymbol(executefunctionbyname.lasterror)
