alloc(newmem,$1000,Factorio.MainLoop::mainLoopStep)

label(return)
label(tele_end)
label(tele_data)
registersymbol(tele_data)

newmem:
mov [rsp+08],rbx

cmp [tele_data],0
je return

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11

  sub rsp,20

  // Get Character
  call Factorio.Global.GetCharacter
  mov rcx,rax
  cmp [tele_data],1
  jne @f
    call Factorio.Entity.GetPositionPointer
    mov rax,[rax]
    mov [tele_data+4],rax
  @@:
  cmp [tele_data],2
  jne tele_end
    //mov rcx,rax
    mov rdx,[tele_data+4]
    xor r8,r8
    xor r9,r9
    test rcx,rcx
    je tele_end
      call Factorio.Entity::teleport

tele_end:
and [tele_data],0

add rsp,20

pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
pop rax
jmp return

tele_data:
dd 0,0,0

address:
  jmp newmem
