          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.SpacePlatformHub::getStatus)
define(bytes,48 89 5C 24 08)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Factorio.SpacePlatformHub::getStatus)

label(code)
label(return)
label(pSpaceStation)
registersymbol(pSpaceStation)

label(skipInventory)

newmem:
mov [rsp+08],rbx
mov [pSpaceStation],rcx
mov ebx,[pSpaceStation+10]
cmp [rcx+C8],ebx
jle code
// Index in Range
mov [rsp+10],rsi
mov [rsp+18],rdi
mov rsi,[rcx+C0] // Inventory
test rsi,rsi
jz skipInventory
  imul rbx,rbx,18
  add rsi,rbx
  mov [pSpaceStation+8],rsi
  // Check if ID was set and update other values
  cmp word ptr [rsi+4],0
  je skipInventory
  // Check if ID is in Range
  mov rdi,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype+8
  mov rdi,[rdi]
  mov rbx,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
  mov rbx,[rbx]
  sub rdi,rbx
  dec rdi
  shr rdi,3
  movzx ebx,word ptr [rsi+4]
  cmp edi,ebx
  cmovs ebx,edi
  mov word ptr [rsi+4],bx
  cmp dword ptr [rsi],0
  jne short @f
    mov dword ptr [rsi],1
  @@:
  cmp byte ptr [rsi+6],0
  jne short @f
    mov byte ptr [rsi+6],1
  @@:
  //cmp byte ptr [rsi+7],0
  //jne skipInventory
    // Set Max Value
    mov rdi,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
    mov rdi,[rdi]
    mov rdi,[rdi+rbx*8]
    test rdi,rdi
    mov bl,-1
    jz short @f
      mov edi,[rdi+384] // Max Stack
      cmp edi,000000FF
      cmovb ebx,edi
    @@:
    mov byte ptr [rsi+7],bl
skipInventory:
mov rdi,[rsp+18]
mov rsi,[rsp+10]
jmp return

code:
  mov qword ptr [pSpaceStation+8],0
  jmp return

align 4 CC

pSpaceStation:
dq 0 // Current SpaceStation
dq 0 // Current Selected Slot
dd 0 // Selected Slot Index

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes
  // mov [rsp+08],rbx

dealloc(newmem)

unregistersymbol(pSpaceStation)

