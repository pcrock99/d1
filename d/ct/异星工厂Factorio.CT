          <ID>442</ID>
          <Description>"Lua Hook"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.LuaContext::update)
define(bytes,48 89 5C 24 08)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Factorio.LuaContext::update)

label(code)
label(return)
label(luaend)
label(LuaData)
registersymbol(LuaData)

label(LuaString)
registersymbol(LuaString)

newmem:
push rcx
push rdx
push r8
push r9
sub rsp,38
mov rcx,Factorio_MainLuaState
mov rcx,[rcx]
jz luaend
mov [rsp+30],rcx
cmp dword ptr [LuaData],0
je luaend
  mov [LuaData],0
  lea rdx,[LuaString]
  call luaL_loadstring
  test eax,eax
  jz short @f
    // Error occured
    mov rcx,[rsp+30]
    call Factorio.Lua.LuaPop
    jmp luaend
  @@:
  mov rcx,[rsp+30]
  xor rdx,rdx
  xor r8,r8
  xor r9,r9
  mov [rsp+20],r9
  call lua_pcallk
  test eax,eax
  jz short @f
    // Error occured
    mov rcx,[rsp+30]
    mov edx,-1
    xor r8,r8
    call lua_tolstring
  @@:
luaend:
add rsp,38
pop r9
pop r8
pop rdx
pop rcx

code:
  mov [rsp+08],rbx
  jmp return

align 4 CC

LuaData:
dd 0 // Run String

LuaString:

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes
  // mov [rsp+08],rbx

dealloc(newmem)

unregistersymbol(*)

