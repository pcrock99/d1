        <CheatEntry>
          <ID>272</ID>
          <Description>"Find Surface"</Description>
          <Options moHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.MainLoop::mainLoopStep+A)
define(bytes,55 57 41 56 48 8D 6C 24 B9)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,Factorio.MainLoop::mainLoopStep+B)

label(code)
label(return)
label(surface.getall)
label(surface.getcount)
label(surface.getsurfacebyindex)
label(surface.getsurfacebyname)
label(surface.find_loop)
label(surface.find_end)
label(surface.find_error)
label(surface.storedata)
label(getsurfaces_data)
label(getsurfacesbyindex)
label(getsurfacesbyname)
label(getsurfaces_end)
label(getsurfaces_retstring)
registersymbol(getsurfaces_retstring)
registersymbol(getsurfaces_data)

newmem:
cmp [getsurfaces_data],1
jne getsurfacesbyindex

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push rbp
  mov rbp,rsp
  sub rsp,20
  and spl,F0

  call surface.getall

  test rax,rax
  je getsurfaces_end

    mov rcx,rax
    call surface.getcount
    mov [getsurfaces_data+4],eax
    jmp getsurfaces_end

getsurfacesbyindex:
cmp [getsurfaces_data],2
jne getsurfacesbyname
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push rbp
  mov rbp,rsp
  sub rsp,20
  and spl,F0

  call surface.getall

  test rax,rax
  je getsurfaces_end
    mov rcx,rax
    mov edx,[getsurfaces_data+8]
    call long surface.getsurfacebyindex
    test rax,rax
    je getsurfaces_end
      mov rcx,rax
      call long surface.storedata
      jmp getsurfaces_end

getsurfacesbyname:
cmp [getsurfaces_data],3
jne code

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push rbp
  mov rbp,rsp
  sub rsp,20
  and spl,F0

  call surface.getall

  test rax,rax
  je getsurfaces_end
    mov rcx,rax
    call surface.getsurfacebyname
    test rax,rax
    je getsurfaces_end
      mov rcx,rax
      call long surface.storedata
      jmp short getsurfaces_end

getsurfaces_end:
and [getsurfaces_data],0

mov rsp,rbp
pop rbp
pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
pop rax

code:
  push rbp
  push rdi
  push r14
  lea rbp,[rsp-47]
  jmp return

surface.getall:
call Factorio.Global.GetSurfaces
ret

surface.getcount:
call Factorio.Global.GetSurfaces
test rax,rax
jz short @f
mov rcx,rax
call Factorio.Global.GetSurfacesEnd
test rax,rax
jz short @f
sub rax,rcx
sar rax,3
@@:
ret

surface.getsurfacebyindex:
push rcx
push rdx
call surface.getcount
pop rdx
pop rcx
cmp edx,eax
jge short @f
  mov rax,[rcx+rdx*8]
  ret
@@:
xor rax,rax
ret


surface.getsurfacebyname:
push rsi
push rdi
sub rsp,28
mov rsi,rax // Factorio.Surface[]
or edi,-1
surface.find_loop: // Loop
inc edi
call surface.getcount
cmp edi,eax
jge surface.find_error
xor eax,eax
mov rcx,[rsi+rdi*8]
lea rcx,[rcx+40] // Surface name
call Factorio.String.GetString
test rax,rax
jz surface.find_loop
mov rcx,rax
lea rdx,[getsurfaces_data+1C] // Name to search for
mov r8,ntdll.strcmp
  mov r9,ntdll.stricmp
  cmp [getsurfaces_data+18],0 // case-sensitive search
  cmove r8,r9
  call r8
  test eax,eax
  jnz surface.find_loop
  mov rax,[rsi+rdi*8]
  jmp surface.find_end
surface.find_error:
xor rax,rax
surface.find_end:
add rsp,28
pop rdi
pop rsi
ret

surface.storedata:
sub rsp,28
mov [getsurfaces_data+10],rcx
mov edx,[rcx+28]
//inc edx
mov [getsurfaces_data+C],edx
lea rcx,[rcx+40]
call Factorio.String.GetString
mov rdx,rax
lea rcx,[getsurfaces_retstring]
test rcx,rcx
je short @f
test rdx,rdx
je short @f
  call ntdll.strcpy
@@:
add rsp,28
ret

getsurfaces_data:
dd 1 // Get Count // Get Data +0
dd 0 // Count +4
dd 0 // Index to Search for +8
dd 0 // Returned Index +C
dq 0 // Returned Address +10
dd 0 // Case Sensitive +18
db '' // String to Search for +1C

newmem+600:
getsurfaces_retstring:
db '' // Returned String

address:
  jmp newmem
  nop 4
return:

[DISABLE]

address:
  db bytes

dealloc(newmem)
unregistersymbol(getsurfaces_data)
unregistersymbol(getsurfaces_retstring)
