        <CheatEntry>
          <ID>356</ID>
          <Description>"Give Item"</Description>
          <Options moHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
aobscanmodule(NewItemStack,Factorio.exe,48 89 5C 24 10 48 89 6C 24 18 48 89 74 24 20 57 48 83 EC 30 48 8B D9) // Factorio.ItemStack::ItemStack

alloc(giveitem.main,0x1000,$process)
registersymbol(giveitem.main)
createthread(giveitem.main)

label(giveitem.main.endloop)
label(giveitem.main.data)
label(giveitem.main.shouldend)
registersymbol(giveitem.main.data)
registersymbol(giveitem.main.giveitembyname.name)

label(giveitem.main.giveitembyid)
label(giveitem.main.giveitembyname)
label(giveitem.main.giveitembyname.name)
label(giveitem.main.giverandom)
label(giveitem.main.name2id)
label(giveitem.main.name2id.end)
label(giveitem.main.idinrange)
label(giveitem.main.countinrange)
label(giveitem.main.giveitembyid.end)
label(giveitem.main.luaprint)
label(giveitem.main.luaprintfunc)
label(giveitem.main.getcursor)
label(giveitem.main.getcharacter)

label(giveitem.main.luaerror_idnotinrange)
label(giveitem.main.luaerror_mapnotfound)
label(giveitem.main.luaerror_characternotfound)
label(giveitem.main.luaerror_cursornotfound)
label(giveitem.main.luaerror_unusualerror)
label(giveitem.main.luaerror_stacktobig)
label(giveitem.main.luaerror_giveitembyid)
label(giveitem.main.luaerror_cursorcontainsitem)
label(giveitem.main.luaerror_namenotfound)

giveitem.main:
mov ecx,A
call KernelBase.Sleep
cmp [giveitem.main.data],1
jne short @f
  and [giveitem.main.data],0
  call long giveitem.main.giveitembyid
@@:
cmp [giveitem.main.data],2
jne short @f
  and [giveitem.main.data],0
  call long giveitem.main.giveitembyname
@@:
cmp [giveitem.main.data],3
jne short @f
  and [giveitem.main.data],0
  call long giveitem.main.giverandom
giveitem.main.endloop:
cmp [giveitem.main.shouldend],1
jne short giveitem.main

// Destroy Thread and free memory
sub rsp,28
lea rcx,[giveitem.main]
xor edx,edx
mov r8d,8000
mov rax,ntdll.RtlExitUserThread
mov [rsp],rax
jmp KernelBase.VirtualFree

giveitem.main.giveitembyname:
mov rcx,giveitem.main.giveitembyname.name
call long giveitem.main.name2id
test rax,rax
je short @f
  mov word ptr [giveitem.main.data+4],ax
  jmp long giveitem.main.giveitembyid
@@:
ret

giveitem.main.name2id:
mov rsi,rcx
xor r13,r13
mov rbx,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
mov rbx,[rbx]
mov r14,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype+8
mov r14,[r14]
@@:
inc r13
lea r12,[rbx+r13*8]
cmp r12,r14
jae giveitem.main.name2id.end
  mov r12,[rbx+r13*8]
  //mov rcx,r12
  //call long giveitem.main.validateptr
  //test rax,rax
  test r12,r12
  je short @b
    mov rdx,rsi
    lea rcx,[r12+8] // Name / *Name
    call Factorio.String.GetString
    mov rcx,rax // Name
    mov r8,ntdll.strcmp
    mov r9,ntdll.stricmp
    cmp [giveitem.main.data+16],0
    cmove r8,r9
    call r8
    test eax,eax
    jnz short @b
    //call long giveitem.main.strcmp
    //test al,al
    //jne short @f
      //mov rcx,[r12+8]
      //call long giveitem.main.validateptr
      //test al,al
      //je short @b
        //mov rdx,rsi
        //call long giveitem.main.strcmp
        //test al,al
        //je short @b
    mov rax,r13
    ret

giveitem.main.name2id.end:
mov rcx,giveitem.main.luaerror_namenotfound
jmp long giveitem.main.luaprint

giveitem.main.giverandom:
push rbx
mov rbx,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
mov rbx,[rbx]
mov rax,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype+8
mov rax,[rax]
sub rax,rbx // Item Count*8
xor rdx,rdx
xor rcx,rcx
or cl,8
div rcx // Item Count
mov rbx,rax // Save Item Count
// Create Semi-Random Number
sub rsp,28
call ntdll.NtGetTickCount
mov [rsp],rax
mov rcx,rsp
call ntdll.RtlRandomEx
add rsp,28
// Create Semi-Random Item ID
xor rdx,rdx
div rbx
inc rdx // Random Item ID
mov word ptr [giveitem.main.data+4],dx // Item ID
mov dword ptr [giveitem.main.data+A],3F800000
mov dword ptr [giveitem.main.data+6],1 // Item Count
call long giveitem.main.giveitembyid
pop rbx
ret

giveitem.main.giveitembyid:
movzx rcx,word ptr [giveitem.main.data+4] // Item ID
call long giveitem.main.idinrange
test rax,rax
je long giveitem.main.giveitembyid.end
  call long giveitem.main.countinrange
  mov [giveitem.main.data+6],eax
  sub rsp,60 // New Item + ItemCreationParameters
  // Get Map
  call giveitem.main.getcharacter
  test rax,rax
  jnz short @f
    add rsp,60
    jmp long giveitem.main.giveitembyid.end
  @@:
  mov rcx,rax
  call Factorio.Entity::getMap
  test rax,rax
  jnz short @f
    add rsp,60
    jmp long giveitem.main.giveitembyid.end
  @@:
  mov rcx,rsp
  lea rdx,[rsp+30] // *ItemCreationParameters
  xorps xmm0,xmm0
  movups [rdx],xmm0
  movups [rdx+10],xmm0
  mov r8d,[giveitem.main.data+6] // Item Count
  // Construct ItemCreationParameters
  mov [rdx],rax // Factorio.Map
  mov eax,[giveitem.main.data+4] // Item ID
  mov qword ptr [rdx+8],0
  // rdx+8 Is Set in NewItemStack to rcx
  mov word ptr [rdx+10],ax // ItemID
  mov al,[giveitem.main.data+1A]
  cmp al,1
  jge short @f
  cmp al,5
  jle short @f
    mov al,1 // Invalid Item Quality
  @@:
  mov byte ptr [rdx+12],al // Item-&gt;+0x6 ItemQuality
  mov eax,[giveitem.main.data+A] // Item Health
  mov [rdx+18],eax // Item Health
  mov dword ptr [rdx+1C],0 // Float (Spoling %?)
  mov byte ptr [rdx+20],0 // Latency Flag
  mov byte ptr [rdx+21],1 // ?
  sub rsp,20
  call NewItemStack
  add rsp,20
  mov rbx,rax
  call long giveitem.main.getcursor
  test rax,rax
  jne short @f
    add rsp,60
    jmp long giveitem.main.giveitembyid.end
  @@:
  cmp [giveitem.main.data+12],1
  je short @f
  cmp word ptr [rax+4],0
  je short @f
    add rsp,60
    mov rcx,giveitem.main.luaerror_cursorcontainsitem
    call long giveitem.main.luaprint
    jmp giveitem.main.giveitembyid.end
  @@:
  mov rcx,rbx
  mov rdx,rax
  sub rsp,20
  call Factorio.ItemStack::swapWith
  add rsp,80
  mov rax,1
  ret

giveitem.main.giveitembyid.end:
mov rcx,giveitem.main.luaerror_giveitembyid
jmp long giveitem.main.luaprint

giveitem.main.idinrange:
mov rax,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
mov rax,[rax]
lea rax,[rax+rcx*8]
mov rdx,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype+8
mov rdx,[rdx]
cmp rax,rdx
jb short @f
  mov rcx,giveitem.main.luaerror_idnotinrange
  jmp long giveitem.main.luaprint
@@:
mov rax,1
ret

giveitem.main.countinrange:
mov rax,Factorio.PrototypeList&lt;ItemPrototype&gt;::indexToPrototype
mov rax,[rax]
movzx rcx,word ptr [giveitem.main.data+4] // Item ID
mov rcx,[rax+rcx*8]
test rcx,rcx
jne short @f
  mov rcx,giveitem.main.luaerror_unusualerror
  jmp long giveitem.main.luaprint
@@:
mov eax,[rcx+384] // Max Amount
cmp [giveitem.main.data+6],eax
jle short @f
  push rcx
  mov rcx,giveitem.main.luaerror_stacktobig
  call long giveitem.main.luaprint
  pop rcx
  mov eax,[rcx+384]
  ret
@@:
mov eax,[giveitem.main.data+6]
ret

giveitem.main.luaprint:
cmp [giveitem.main.data+E],1
je short @f
  xor rax,rax
  ret
@@:
push rbp
mov rbp,rsp
sub rsp,20
and spl,F0
mov rdx,rcx
mov rcx,giveitem.main.luaprintfunc
call CELUA_ExecuteFunction
mov rsp,rbp
pop rbp
ret

giveitem.main.getcursor:
call long Factorio.Global.GetCursor
test rax,rax
je short @f
  ret
@@:
mov rcx,giveitem.main.luaerror_cursornotfound
jmp long giveitem.main.luaprint

giveitem.main.getcharacter:
call long Factorio.Global.GetCharacter
test rax,rax
je short @f
  ret
@@:
mov rcx,giveitem.main.luaerror_characternotfound
jmp long giveitem.main.luaprint

align 4 CC

giveitem.main.shouldend:
dd 0

giveitem.main.data:
dd 0 // What to do +0
dw 1 // Item ID +4
dd 1 // Item Count +6
dd 3F800000 // Item Health +A
dd 1,0 // Print Errors+Warnings / ForceReplace
dd 0 // Handle String Compare Casesensitive
dd 1 // Item Quality +1A

giveitem.main.luaprintfunc:
db 'print(readString(parameter,256))',0

giveitem.main.luaerror_idnotinrange:
db 'Error:The Item ID specified is not inside the range of possible IDs',0
giveitem.main.luaerror_mapnotfound:
db 'Error:A Pointer to Factorio.Map could not be found!',0
giveitem.main.luaerror_characternotfound:
db 'Error:A Pointer to Factorio.Character could not be found!',0
giveitem.main.luaerror_cursornotfound:
db 'Error:A Pointer to Factorio.Cursor could not be found!',0
giveitem.main.luaerror_unusualerror:
db 'Error:An Unusual Error occured!',0
giveitem.main.luaerror_stacktobig:
db 'Warning:The Item Count specified is to big and has been adjusted to be the max Amount',0
giveitem.main.luaerror_giveitembyid:
db 'ERROR:Something went wrong while trying to run the GiveItemById Function',0
giveitem.main.luaerror_cursorcontainsitem:
db 'Error:There is still a Item in the Cursor Slot!',0
giveitem.main.luaerror_namenotfound:
db 'Error:No Item with this Name could be found!',0

giveitem.main.giveitembyname.name:
db '',0

[DISABLE]
{$lua}
if syntaxcheck then return end
if writeInteger(getAddressSafe("giveitem.main.data-4"),1) then
  unregisterSymbol("giveitem.main")
  unregisterSymbol("giveitem.main.data")
  unregisterSymbol("giveitem.main.giveitembyname.name")
end
