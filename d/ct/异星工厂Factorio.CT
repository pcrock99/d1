        </CheatEntry>
        <CheatEntry>
          <ID>267</ID>
          <Description>"Change Surface Activate Me First"</Description>
          <Options moHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Factorio.MainLoop::mainLoopStep+5)
define(bytes,48 89 74 24 10)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,Factorio.MainLoop::mainLoopStep+5)

label(code)
label(return)
label(surface.getall)
label(surface.getcount)
label(getcharactercontroller)
label(surface.find)
label(surface.find_loop)
label(surface.find_error)
label(surface.find_end)
label(changesurface_data)
label(changesurface_end)
registersymbol(changesurface_data)

newmem:
cmp [changesurface_data],0
je code

  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push rsi
  push rdi
  sub rsp,30

  call surface.find
  test rax,rax
  jz changesurface_end

  mov rsi,rax // Found Surface
  call getcharactercontroller
  test rax,rax
  jz changesurface_end
  mov rcx,rax // CharacterController
  mov rdx,rsi // Found Surface
  lea r8,[changesurface_data+4] // X/Y Pos
  call Factorio.CharacterController::changeSurfaceAndPosition

changesurface_end:

add rsp,30
pop rdi
pop rsi
pop r11
pop r10
pop r9
pop r8
pop rdx
pop rcx
pop rax

mov dword ptr [changesurface_data],0

code:
  mov [rsp+10],rsi
  jmp return

align 4 CC

surface.getall:
call Factorio.Global.GetSurfaces
ret

surface.getcount:
call Factorio.Global.GetSurfaces
test rax,rax
jz short @f
mov rcx,rax
call Factorio.Global.GetSurfacesEnd
test rax,rax
jz short @f
sub rax,rcx
sar rax,3
@@:
ret

getcharactercontroller:
call Factorio.Global.GetCharacterController
ret

surface.find:
sub rsp,28
call surface.getall
test rax,rax
jz surface.find_end
  mov rsi,rax // Factorio.Surface[]
  or edi,-1
  surface.find_loop: // Loop
  inc edi
  call surface.getcount
  cmp edi,eax
  jge surface.find_error
  xor eax,eax
  mov rcx,[rsi+rdi*8]
  cmp [changesurface_data],2
  jne short @f
    // Get By Index
    lea ecx,[edi+1]
    cmp [changesurface_data+10],ecx // Index to change to
    jne surface.find_loop
    mov rax,[rsi+rdi*8] // Surface
    jmp surface.find_end
  @@:
  // Get By Name
  mov rcx,[rsi+rdi*8]
  lea rcx,[rcx+40] // Surface name
  call Factorio.String.GetString
  test rax,rax
  jz surface.find_loop
  mov rcx,rax
  lea rdx,[changesurface_data+18] // Name to search for
  mov r8,ntdll.strcmp
  mov r9,ntdll.stricmp
  cmp [changesurface_data+14],0 // case-sensitive search
  cmove r8,r9
  call r8
  test eax,eax
  jnz surface.find_loop
  mov rax,[rsi+rdi*8]
  jmp surface.find_end
surface.find_error:
// Surface not found
cmp [changesurface_data],1
jne short @f
  // Name not found
  lea rcx,[newmem+900]
  call Factorio.PrintToLua
@@:
cmp [changesurface_data],2
jne short @f
  // Index not found
  lea rcx,[newmem+800]
  call Factorio.PrintToLua
@@:
xor rax,rax
surface.find_end:
add rsp,28
ret

align 4 CC

changesurface_data:
dd 0 // Switch Value +0
dd 0 // X +4
dd 0 // Y +8
dd 0 // Reserved +C
dd 1 // Index to change to // 1 is first Index +10
dd 0 // Case-sensitive search +14
db '' // Name to search for +18

newmem+800:
db 'Error:A Surface with this index does not exist!',0
newmem+900:
db 'Error:A Surface with this name does not exist!',0

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes

dealloc(newmem)
unregistersymbol(changesurface_data)
</AssemblerScript>
