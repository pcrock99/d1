<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>295</ID>
      <Description>"Bloodybone"</Description>
      <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
{$lua}
if syntaxcheck then return end

if not getAddressSafe("luaclient-x86_64.dll") then
  autoAssemble([[
  loadlibrary(luaclient-x86_64.dll)
  luacall(openLuaServer('CELUASERVER'))

  CELUA_ServerName:
  db 'CELUASERVER',0
  ]])
end

local HookFactorioLua = false

if (HookFactorioLua) then
  local luaccheckstackaddr = getAddressSafe('Factorio.lua_checkstack')
  if (not luaccheckstackaddr) then
    print("Failed to get Address of 'Factorio.lua_checkstack'!")
  else
    if (readBytes(luaccheckstackaddr,1,false) == 0xE9) then
      local offset = signExtend(readInteger(luaccheckstackaddr+1),31)
      f_checkstack_locked_addr = luaccheckstackaddr+offset+5
      local script = [==[
      alloc(Factorio_LuahookMem,$1000,$process)
      registersymbol(Factorio_LuahookMem)
      assert($f_checkstack_locked_addr,48 89 5C 24 08)

      label(return)
      label(Factorio_MainLuaState)
      registersymbol(Factorio_MainLuaState)

      label(Factorio_NewLuaState)
      registersymbol(Factorio_NewLuaState)

      label(newluaStackSkip)

      Factorio_LuahookMem:
      mov [Factorio_MainLuaState],rcx
      mov [rsp+8],rbx
      cmp qword ptr [Factorio_NewLuaState],0
      jmp newluaStackSkip
      jne newluaStackSkip
        // Create New Lua Stack/Thread
        push rcx
        push rdx
        push r8
        push r9
        sub rsp,28
        mov [rsp+20],rcx
        call lua_newthread
        mov [Factorio_NewLuaState],rax
        mov rcx,[rsp+20]
        mov edx,-2
        call lua_settop
        add rsp,28
        pop r9
        pop r8
        pop rdx
        pop rcx
      newluaStackSkip:
      jmp return

      align 10 CC

      Factorio_MainLuaState:
      dq 0
      Factorio_NewLuaState:
      dq 0

      $f_checkstack_locked_addr:
      jmp long Factorio_LuahookMem
      return:
      ]==]
      if (not autoAssemble(script)) then
        print("Failed to assemble script 'LuaHook'!")
      end
    else
      print("Invalid Instruction at 'Factorio.lua_checkstack'!")
    end
  end
end

--reinitializeSymbolhandler(false)

{$asm}
alloc(HelperMem,0x1000,$process)

label(Factorio.String.IsPointer)
registersymbol(Factorio.String.IsPointer)

label(Factorio.String.GetLength)
registersymbol(Factorio.String.GetLength)

