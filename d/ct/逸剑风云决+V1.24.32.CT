        <CheatEntry>
          <ID>249</ID>
          <Description>"切换到奔跑或骑马时替换为指定坐骑"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
luacall(addDropDownList('指定坐骑', MountStr, false, false, true))
aobscanmodule(aobChangeMount,$process,83 B9 x x 00 00 00 7E x 48 89 x 24 x E8) // should be unique
alloc(changeMount,$1000,aobChangeMount)
label(return,offset)

[aobChangeMount+2]:
offset:
changeMount+200:
  dd 9
changeMount:
  readmem(aobChangeMount,7)
  push rax
  mov eax,[changeMount+200]
  mov [rcx+offset],eax
  pop rax
  readmem(aobChangeMount,7)
  jmp return
aobChangeMount:
  jmp changeMount
  nop 2
return:
registersymbol(aobChangeMount,changeMount)


[DISABLE]
aobChangeMount:
  readmem(changeMount,7)
dealloc(changeMount)
unregistersymbol(*)
</AssemblerScript>
