{$asm}
[ENABLE]
aobscanmodule(aobEquiptAttr,$process,48 8B 06 41 B0 01 48 8D 54 24 x 48 8B CE FF 90 x x 00 00 48 8B D6)
alloc(EquiptAttr,$1000,aobEquiptAttr)
label(return,exit)

EquiptAttr:
  push r8
  cmp byte ptr [rbx+45],1
  jne exit
  cmp [EquiptAttr+300],1
  jne @f
  cmp [EquiptAttr+200],rbx
  je exit
@@:
  mov [EquiptAttr+200],rbx
  mov r8,[rbx+70]
  lea r8,[r8+A0]
  mov [EquiptAttr+208],r8
  cmp [EquiptAttr+400],1
  je exit
  mov [EquiptAttr+400],1
{$luacode _ItemInfoSpec=RBX _ItemInfoSetting=R8}
  synchronize(updateActions(_ItemInfoSpec,_ItemInfoSetting))
{$asm}
  mov [EquiptAttr+400],0
exit:
  pop r8
  mov rax,[rsi]
  mov r8l,01
  jmp return
aobEquiptAttr:
  jmp EquiptAttr
  nop
return:
registersymbol(aobEquiptAttr,EquiptAttr)


