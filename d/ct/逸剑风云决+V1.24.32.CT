label(returnhere)
StrongEnough:
  readmem(INJECT_songli2+7,8)
  cmp [StrongEnough+200],1
  jne @f
  cmp [rsi+38],0
  jne @f
  mov [StrongEnough+200],0
  push (float)99999
  movss xmm0,[rsp]
  add rsp,8
@@:
  jmp returnhere
INJECT_songli2+7:
  jmp StrongEnough
  nop 3
returnhere:
