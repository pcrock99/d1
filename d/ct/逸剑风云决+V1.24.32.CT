        <CheatEntry>
          <ID>228</ID>
          <Description>"锻造、制衣、炼丹、烹饪无视要求"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local scan = AOBScan('83 x FE 0F 85 x x x x 4C 8D 0D','+X-C')
if scan then
  for i=0,scan.count-1 do writeBytes(scan[i]..'+3',0x90,0xE9) end
  scan.destroy()
  scan = nil
end
local scan = AOBScan('x 8B x 49 8B x E8 x x x x 84 C0 0F 85 x x 00 00 4C 8D 0D','+X-C')
if scan then
  for i=0,scan.count-1 do writeBytes(scan[i]..'+B',0x0C,0x01) end
  scan.destroy()
  scan = nil
end
{$asm}
aobscanmodule(IgnoreForgeLevel,$process,x 89 x x 48 8D 55 x 48 8B x E8 x x x x 84 C0 0F 85)
aobscanmodule(forgeMaterialEnough,$process,48 8D 55 x 48 8B x E8 x x x x 84 C0 0F 85 x x x x 84 DB 0F 85)
IgnoreForgeLevel+10:
  db 0C 01
forgeMaterialEnough+C:
  db 0C 01
registersymbol(IgnoreForgeLevel,forgeMaterialEnough)

aobscanmodule(fusionType,$process,48 8B 79 08 85 D2 0F 8E)
alloc(setFusionType,$1000,fusionType)
label(return)
setFusionType:
  mov edx,2
  mov rdi,[rcx+08]
  test edx,edx
  jmp return
fusionType:
  jmp setFusionType
  nop
return:
registersymbol(fusionType,setFusionType)

aobscanmodule(AlchemyMonneyIsEnough,$process,39 x 30 0F 8D x x 00 00 4C 8D)
aobscanmodule(CookingMonneyIsEnough,$process,39 x 30 7D x 4C 8D)
aobscanmodule(AlchemyLvIsEnough,$process,8B x 6C 49 8B x E8 x x x x 84 C0)
aobscanmodule(CookingLvIsEnough,$process,8B x x 49 8B x E8 x x x x 84 C0 75 x 4C 8D)
AlchemyMonneyIsEnough+3:
  db 90 E9
CookingMonneyIsEnough+3:
  db EB
AlchemyLvIsEnough+B:
  db 0C 01
CookingLvIsEnough+B:
  db 0C 01
registersymbol(AlchemyMonneyIsEnough,CookingMonneyIsEnough,AlchemyLvIsEnough,CookingLvIsEnough)

aobscanmodule(FusionAlertCont,$process,8B 81 04 03 00 00 89 44 24)
alloc(setFusionAlertCont,$1000,FusionAlertCont)
label(returnhere)
setFusionAlertCont+204:
  dd 2
setFusionAlertCont:
  mov eax,[rcx+304]
  cmp [setFusionAlertCont+200],1
  jne @f
  mov eax,[setFusionAlertCont+204]
@@:
  cmp eax,0
  jg @f
  mov eax,1
@@:
  mov [rcx+304],eax
  jmp returnhere
FusionAlertCont:
  jmp setFusionAlertCont
  nop
returnhere:
registersymbol(FusionAlertCont,setFusionAlertCont)


[DISABLE]
{$lua}
if syntaxcheck then return end
local scan = AOBScan('83 x FE 90 E9 x x x x 4C 8D 0D','+X-C')
if scan then
  for i=0,scan.count-1 do writeBytes(scan[i]..'+3',0x0F,0x85) end
  scan.destroy()
  scan = nil
end
local scan = AOBScan('x 8B x 49 8B x E8 x x x x 0C 01 0F 85 x x 00 00 4C 8D 0D','+X-C')
if scan then
  for i=0,scan.count-1 do writeBytes(scan[i]..'+B',0x84,0xC0) end
  scan.destroy()
  scan = nil
end
{$asm}
IgnoreForgeLevel+10:
  db 84 C0
forgeMaterialEnough+C:
  db 84 C0
fusionType:
  db 48 8B 79 08 85 D2
dealloc(setFusionType)

AlchemyMonneyIsEnough+3:
  db 0F 8D
CookingMonneyIsEnough+3:
  db 7D
AlchemyLvIsEnough+B:
  db 84 C0
CookingLvIsEnough+B:
  db 84 C0

FusionAlertCont:
  db 8B 81 04 03 00 00
dealloc(setFusionAlertCont)
unregistersymbol(*)
