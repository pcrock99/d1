label(GiftQuality)
label(return)
newmem:
  mov [StrongEnough+200],1
  cmp al,byte ptr [GiftQuality]
  jge @f
  mov al,byte ptr [GiftQuality]
@@:
  mov [rdi+00000080],al
  jmp return
  align 10
GiftQuality:
  db 5
registersymbol(GiftQuality)
songli_quality:
  jmp newmem
  nop
return:
registersymbol(songli_quality)

