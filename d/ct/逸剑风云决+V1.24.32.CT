alloc(ShowGMCommandLine,$1000,$process)
label(exit)
registersymbol(ShowGMCommandLine)
ShowGMCommandLine:
  readmem(Stack+200,31)
  sub rsp,8
  call GMCommandLine
  add rsp,8
exit:
  readmem(Stack+21F,32)

[DISABLE]
dealloc(ShowGMCommandLine)
unregistersymbol(*)
unregistersymbol(GMCommandLine)
</AssemblerScript>
