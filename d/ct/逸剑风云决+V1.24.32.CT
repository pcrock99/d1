        <CheatEntry>
          <ID>223</ID>
          <Description>"锻造和制衣效果加倍"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
aobscanmodule(InForging,$process,0F 10 00 0F 11 46 28 44 89)
aobscanmodule(ForgeEffect,$process,E8 x x x x F2 0F 10 x 44 8B 78 08 F2 0F 11 x 24)
aobscanmodule(ForgeRandEffect,$process,0F 29 x 24 x 0F 28 x 0F 29 x 24 x F2 0F 10)
alloc(Forge,$1000,InForging)
registersymbol(InForging,ForgeEffect,ForgeRandEffect,Forge)
label(return,return1,return2)

Forge:
  movups xmm0,[rax]
  movups [rsi+28],xmm0
  mov [Forge+A0],r15d
  jmp return
InForging:
  jmp Forge
  nop 2
return:

Forge+100:
  dd (float)2 (float)2

Forge+1F0:
  readmem(ForgeEffect+5,8)
Forge+200:
  cmp [Forge+A0],2
  jne @f
  fld [rax+8]
  fmul [Forge+100]
  fstp [rax+8]
@@:
  readmem(ForgeEffect+5,8)
  jmp return1
ForgeEffect+5:
  jmp Forge+200
  nop 3
return1:

Forge+300:
  readmem(ForgeRandEffect,5)
  cmp [Forge+A0],2
  jne @f
  cmp [rcx],5
  je @f
  cmp [rcx],6
  je @f
  movss xmm2,[Forge+104]
@@:
  jmp return2
ForgeRandEffect:
  jmp Forge+300
return2:


[DISABLE]
InForging:
  db 0F 10 00 0F 11 46 28
ForgeEffect+5:
  readmem(Forge+1F0,8)
ForgeRandEffect:
  readmem(Forge+300,5)
dealloc(Forge)
unregistersymbol(*)
</AssemblerScript>
