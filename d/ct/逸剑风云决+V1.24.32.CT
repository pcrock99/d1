        <CheatEntry>
          <ID>179</ID>
          <Description>"Ctrl键跳跃"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
if syntaxcheck then return end
[ENABLE]
local keycode = 0x11---Ctrl键
hk_jump = createHotkey(jump,keycode)

--[=[
keycode键值表：
0x08 Backspace键
0x09 Tab键
0x0C Clear键 Num Lock关闭时的数字键盘5
0x0D Enter键
0x10 Shift键
0x11 Ctrl键
0x12 Alt键
0x13 Pause键
0x14 Caps Lock键
0x1B Esc键
0x20 Spacebar键
0x21 Page Up键
0x22 Page Down键
0x23 End键
0x24 Home键
0x25 LEFT ARROW键
0x26 UP ARROW键
0x27 RIGHT ARROW键
0x28 DOWN ARROW键
0x29 Select键
0x2A Print键
0x2B Execute键
0x2D Insert键 Num Lock关闭时的数字键盘0
0x2E Delete键 Num Lock关闭时的数字键盘.
0x2F Help键
0x30 0键
0x31 1键
0x32 2键
0x33 3键
0x34 4键
0x35 5键
0x36 6键
0x37 7键
0x38 8键
0x39 9键
0x41 A键
0x42 B键
0x43 C键
0x44 D键
0x45 E键
0x46 F键
0x47 G键
0x48 H键
0x49 I键
0x4A J键
0x4B K键
0x4C L键
0x4D M键
0x4E N键
0x4F O键
0x50 P键
0x51 Q键
0x52 R键
0x53 S键
0x54 T键
0x55 U键
0x56 V键
0x57 W键
0x58 X键
0x59 Y键
0x5A Z键
0x60 数字键0键
0x61 数字键1键
0x62 数字键2键
0x63 数字键3键
0x64 数字键4键
0x65 数字键5键
0x66 数字键6键
0x67 数字键7键
0x68 数字键8键
0x69 数字键9键
0x6A 数字键盘上的*键
0x6B 数字键盘上的+键
0x6C Separator键
0x6D 数字键盘上的-键
0x6E 数字键盘上的.键
0x6F 数字键盘上的/键
0x70 F1键
0x71 F2键
0x72 F3键
0x73 F4键
0x74 F5键
0x75 F6键
0x76 F7键
0x77 F8键
0x78 F9键
0x79 F10键
0x7A F11键
0x7B F12键
0x90 Num Lock键
0x91 Scroll Lock键
0x5B 左win键
0x5C 右win键
0x5D 右Ctrl左边键 相当于鼠标右键
0xBA ;（分号）键
0xBB =键
0xBC ,（逗号）键
0xBD -（减号）键
0xBE .（句号）键
0xBF /键
0xC0 `键（Esc下面）
0xDB [键
0xDC \键
0xDD ]键
0xDE ‘（引号）键
--]=]

[DISABLE]
hk_jump.destroy()
hk_jump = nil
</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>180</ID>
              <Description>"跳跃速度"</Description>
              <ShowAsSigned>0</ShowAsSigned>
              <VariableType>Float</VariableType>
              <Address>[GameEngine]+DE8</Address>
              <Offsets>
                <Offset>[Stack+1C8]</Offset>
                <Offset>[Stack+1C0]</Offset>
                <Offset>[Stack+1B8]</Offset>
                <Offset>30</Offset>
                <Offset>0</Offset>
                <Offset>38</Offset>
              </Offsets>
            </CheatEntry>
            <CheatEntry>
              <ID>181</ID>
              <Description>"无限跳跃"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
aobscanmodule(jumpCount,$process,8B 87 x x 00 00 39 87 x x 00 00 0F 9C C0)
jumpCount+C:
  db 83 C8 01
registersymbol(jumpCount)

[DISABLE]
jumpCount+C:
  db 0F 9C C0
unregistersymbol(jumpCount)
</AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>183</ID>
          <Description>"设置队友跟随数量"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
aobscanmodule(setFollower,$process,44 3B BE x 05 00 00 0F 8C)
alloc(duiyoushuliang,$1000,setFollower)
label(return)

duiyoushuliang:
  readmem(setFollower,7)
  push rax
  mov eax,[duiyoushuliang+200]
  inc eax
  cmp r15d,eax
  pop rax
  jmp return
duiyoushuliang+200:
  dd #99
setFollower:
  jmp duiyoushuliang
  nop 2
return:
registersymbol(setFollower,duiyoushuliang)


[DISABLE]
setFollower:
  readmem(duiyoushuliang,7)
dealloc(duiyoushuliang)
unregistersymbol(*)
</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>182</ID>
              <Description>"队友跟随数量"</Description>
              <ShowAsSigned>1</ShowAsSigned>
              <VariableType>4 Bytes</VariableType>
              <Address>duiyoushuliang+200</Address>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
