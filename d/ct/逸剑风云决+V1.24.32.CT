aobscanmodule(SkillSetting,$process,F3 0F 10 80 D0 01 00 00 41 0F 2F C2)
alloc(newmem,$1000,SkillSetting)
label(DamageMultiplier)
label(return)

newmem:
  movss xmm0,[rax+000001D0]
  mov [DamageMultiplier+8],0
  cmp r15,rsp
  jna @f
{$luacode JHASC=r15}
  mulDamage(JHASC)
