{
  "村口": {
    "desc": "阴冷的风把眼前的迷雾吹散了一些，隐约看到前方有一座古宅",
    "exits": {"北": "古宅大门"},
    "on_enter": "treasure_msg"
  },
  "古宅大门": {
    "desc": "一座阴森的古宅，大门虚掩着，门上有把奇怪的锁。",
    "exits": {"北": "前院", "南": "村口"},
    "puzzle": {
      "id": "gate",
      "type": "riddle",
      "question": "什么东西越拿越多？",
      "answer": "洞",
      "hint": "想想手上有什么"
    }
  },
  "前院": {
    "desc": "杂草丛生的院子，中央有口古井，井边刻着奇怪的符号。",
    "exits": {"南": "古宅大门", "北": "大厅"},
    "puzzle": {
      "id": "well",
      "type": "riddle",
      "question": "什么东西越洗越脏？",
      "answer": "水",
      "hint": "想想洗东西的时候"
    }
  },
  "大厅": {
    "desc": "宽敞的大厅，墙上挂着一幅古老的画像，画像的眼睛似乎在盯着你。",
    "exits": {"南": "前院", "东": "密室"},
    "puzzle": {
      "id": "portrait",
      "type": "code",
      "hint": "画像下面刻着：'四八十五十六'",
      "answer": "481516",
      "max_attempts": 3,
      "success_msg": "画像移开，露出一条密道！"
    }
  },
  "密室": {
    "desc": "一间布满灰尘的密室，角落里有个宝箱。",
    "exits": {"西": "大厅"},
    "on_enter": "treasure_msg"
  }
}